generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== ENUMS =====

enum Role {
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum StoreType {
  RESTAURANT
  MARKET
  PHARMACY
  OTHER
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DomainStatus {
  PENDING
  WAITING_DNS
  SSL
  CONNECTED
  FAILED
}

enum PaymentType {
  CASH
  INSTAPAY
  BANK_WALLET
  BANK_TRANSFER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PENDING_PAYMENT
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
  ARCHIVED
}

enum PaymentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum AdminNotificationType {
  NEW_USER
  SYSTEM
}

// ===== MODELS =====

model User {
  id             String     @id @default(cuid())
  name           String
  email          String     @unique
  password       String
  phone          String?
  role           Role       @default(OWNER)
  status         UserStatus @default(ACTIVE)
  store          Store?
  otpCode        String?
  otpExpiry      DateTime?
  isVerified     Boolean    @default(true)
  onboardingStep Int        @default(1)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Store {
  id          String      @id @default(cuid())
  name        String
  description String?
  logo        String?
  type        StoreType   @default(RESTAURANT)
  subdomain   String?     @unique
  status      StoreStatus @default(ACTIVE)
  phone       String?
  address     String?
  currency    String      @default("EGP")

  // Social & Contact & Branding
  primaryColor         String?
  whatsappNumber       String?
  enableWhatsappOrders Boolean @default(true)
  facebookUrl          String?
  showFacebook         Boolean @default(true)
  instagramUrl         String?
  showInstagram        Boolean @default(true)
  twitterUrl           String?
  showTwitter          Boolean @default(true)
  tiktokUrl            String?
  showTiktok           Boolean @default(true)
  snapchatUrl          String?
  showSnapchat         Boolean @default(true)
  showDefaultProducts  Boolean @default(true)
  fontFamily           String  @default("Tajawal")

  // Relations
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories     Category[]
  menuItems      MenuItem[]
  banners        StoreBanner[]
  orders         Order[]
  coupons        Coupon[]
  paymentMethods PaymentMethod[]
  branches       Branch[]
  deliveryAreas  DeliveryArea[]
  domains        Domain[]
  subscription   Subscription?
  paymentRequests PaymentRequest[]
  subscriptionHistory SubscriptionHistory[]
  notifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subdomain])
  @@index([userId])
}

model Branch {
  id           String  @id @default(cuid())
  name         String
  address      String?
  phone        String?
  workingHours String?
  isActive     Boolean @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model Domain {
  id           String       @id @default(cuid())
  name         String       @unique // e.g., restaurant.com
  status       DomainStatus @default(PENDING)
  dnsRecords   Json?        // Vercel DNS instructions
  
  storeId      String
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  verifiedAt   DateTime?
  sslIssuedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([storeId])
}

model DeliveryArea {
  id          String  @id @default(cuid())
  name        String
  deliveryFee Decimal @db.Decimal(10, 2)
  isActive    Boolean @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model PaymentMethod {
  id           String      @id @default(cuid())
  type         PaymentType
  name         String
  details      String?
  instructions String?
  isEnabled    Boolean     @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model Category {
  id          String  @id @default(cuid())
  name        String
  description String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  storeId String
  store   Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items   MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model MenuItem {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  image       String?
  isAvailable Boolean @default(true)
  sortOrder   Int     @default(0)

  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  storeId    String
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  sizes      MenuItemSize[]
  addons     MenuItemAddon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, categoryId])
  @@index([storeId])
  @@index([storeId, isAvailable])
  @@index([storeId, sortOrder])
}

model MenuItemSize {
  id         String  @id @default(cuid())
  name       String
  price      Decimal @db.Decimal(10, 2)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model MenuItemAddon {
  id         String  @id @default(cuid())
  name       String
  price      Decimal @db.Decimal(10, 2)

  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([menuItemId])
}

model Coupon {
  id          String     @id @default(cuid())
  code        String
  type        CouponType @default(PERCENTAGE)
  value       Decimal    @db.Decimal(10, 2)
  minOrder    Decimal?   @db.Decimal(10, 2)
  maxDiscount Decimal?   @db.Decimal(10, 2)
  usageLimit  Int?
  usedCount   Int        @default(0)
  isActive    Boolean    @default(true)
  expiresAt   DateTime?

  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders  Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, storeId])
  @@index([storeId])
  @@index([code, storeId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     Int
  customerName    String
  customerPhone   String
  customerAddress String?
  notes           String?

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentType   @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)
  paymentProof  String?

  deliveryType   DeliveryType @default(DELIVERY)
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])
  deliveryAreaId String?
  deliveryArea   DeliveryArea? @relation(fields: [deliveryAreaId], references: [id])

  subtotal    Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  storeId String
  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items   OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([storeId, status])
  @@index([storeId, createdAt])
  @@index([storeId, paymentStatus])
}

model OrderItem {
  id       String  @id @default(cuid())
  name     String
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  notes    String?
  
  // JSON to store selected size and addons to preserve historical data
  selectedSize   String? 
  selectedAddons String?

  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model PlatformSetting {
  id              String   @id @default("1")
  name            String   @default("منصتك")
  logo            String?
  supportWhatsapp String?
  enableEmailOtp  Boolean  @default(false)
  enablePhoneOtp  Boolean  @default(true)
  
  // Subscription Settings
  trialDays       Int      @default(7)
  graceDays       Int      @default(3)
  archiveDays     Int      @default(30)
  
  updatedAt       DateTime @updatedAt
}

model AdminNotification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      AdminNotificationType @default(NEW_USER)
  link      String?
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
}

model Plan {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  durationDays    Int      @default(30)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  // JSON field for all feature flags & limits
  // e.g., { "products": 300, "branches": 3, "staff": 5, "reports": true, "qr": true, "ai": false }
  features        Json     @default("{}")

  subscriptions   Subscription[]
  paymentRequests PaymentRequest[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id              String   @id @default(cuid())
  storeId         String   @unique
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  planId          String?
  plan            Plan?    @relation(fields: [planId], references: [id])
  
  status          SubscriptionStatus @default(TRIAL)
  startDate       DateTime @default(now())
  endDate         DateTime
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
}

model PlatformPaymentMethod {
  id           String  @id @default(cuid())
  name         String
  logo         String?
  accountInfo  String
  instructions String?
  qrCode       String?
  isActive     Boolean @default(true)
  sortOrder    Int     @default(0)

  paymentRequests PaymentRequest[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentRequest {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  planId          String
  plan            Plan     @relation(fields: [planId], references: [id])
  
  methodId        String
  method          PlatformPaymentMethod @relation(fields: [methodId], references: [id])
  
  amount          Decimal  @db.Decimal(10, 2)
  receiptImage    String
  transactionId   String?
  status          PaymentRequestStatus @default(PENDING)
  notes           String?
  
  reviewedBy      String?
  reviewedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
}

model SubscriptionHistory {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  action          String   // e.g., "CREATED", "RENEWED", "PLAN_CHANGED", "PAYMENT_REJECTED"
  details         String?
  
  createdAt       DateTime @default(now())

  @@index([storeId])
}

model Notification {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  
  title           String
  message         String
  type            String   @default("SYSTEM") // e.g., "BILLING", "SYSTEM", "ALERT"
  isRead          Boolean  @default(false)
  
  createdAt       DateTime @default(now())

  @@index([storeId])
}

model StoreBanner {
  id        String  @id @default(cuid())
  image     String
  title     String?
  link      String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}
